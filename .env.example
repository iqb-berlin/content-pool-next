# ── Database ──────────────────────────────────────────────
DB_USERNAME=contentpool
DB_PASSWORD=change-me-to-a-secure-password
DB_DATABASE=contentpool

# ── JWT ──────────────────────────────────────────────────
JWT_SECRET=change-me-to-a-random-string-at-least-32-chars
JWT_EXPIRATION=24h

# ── App Port (nginx) ────────────────────────────────────
APP_PORT=80

# ── CORS ────────────────────────────────────────────────
CORS_ORIGIN=*

# ── OIDC / Keycloak (optional) ──────────────────────────
# If set, a Keycloak login button appears on the login page.
# Leave empty to disable OIDC.
OIDC_ISSUER_URL=
OIDC_CLIENT_ID=
OIDC_REDIRECT_URI=
OIDC_SCOPE=openid profile email

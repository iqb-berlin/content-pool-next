# ── Deployment / Image ───────────────────────────────────
# For docker-compose.server.yml (GHCR images): set tag like v0.1.0
IMAGE_VERSION=latest
APP_PORT=80

# ── App Database (PostgreSQL) ────────────────────────────
POSTGRES_DB=content_pool
POSTGRES_USER=content_pool
POSTGRES_PASSWORD=change-me-to-a-secure-password

# ── App Security ──────────────────────────────────────────
JWT_SECRET=change-me-to-a-random-string-at-least-32-chars
JWT_EXPIRATION=24h
# Credential login rate limiting (ACP access list logins)
CREDENTIAL_LOGIN_MAX_ATTEMPTS=5
CREDENTIAL_LOGIN_WINDOW_MS=900000
CREDENTIAL_LOGIN_BLOCK_MS=900000
SWAGGER_ENABLED=false
SEED_DEFAULT_ADMIN=false
# Production-safe defaults: migrations on startup, no schema sync
DB_SYNCHRONIZE=false
DB_RUN_MIGRATIONS=true

# Server-to-server API integration tokens (JSON array)
# Example:
# SERVER_API_TOKENS=[{"id":"studio","token":"change-me-very-long-token","scopes":["transfer.read","files.read"]}]
# Optional legacy fallback (full scope access):
# SERVER_API_KEY=change-me-legacy-server-token

# Browser origin of the ContentPool frontend
CORS_ORIGIN=https://app.example.com

# ── Keycloak / OIDC (secure default: reverse proxy + HTTPS) ──
# Public hostname users open in browser (typically auth subdomain)
KEYCLOAK_HOSTNAME=auth.example.com

KC_PROXY=edge
KC_HTTP_ENABLED=true
KC_HOSTNAME_STRICT=true
KC_HOSTNAME_STRICT_HTTPS=true
KEYCLOAK_HOSTNAME_STRICT_BACKCHANNEL=false

# Keep Keycloak bound to localhost only (admin via SSH tunnel)
KEYCLOAK_PORT_EXPOSE=127.0.0.1:8080:8080

# Internal issuer for backend-to-keycloak traffic
OIDC_ISSUER_URL=http://keycloak:8080/realms/iqb
# Public issuer for browser redirects/discovery
OIDC_PUBLIC_ISSUER_URL=https://auth.example.com/realms/iqb
OIDC_REDIRECT_URI=https://app.example.com/auth/callback
OIDC_CLIENT_ID=contentpool
OIDC_SCOPE=openid profile email

# ── Keycloak Database (separate PostgreSQL) ───────────────
KEYCLOAK_DB_NAME=keycloak
KEYCLOAK_DB_USER=keycloak
KEYCLOAK_DB_PASSWORD=change-me-to-a-secure-password-for-keycloak-db

# ── Keycloak Admin ────────────────────────────────────────
KEYCLOAK_ADMIN_USER=admin
KEYCLOAK_ADMIN_PASSWORD=change-me-to-a-very-secure-password-min-12-chars

# ── Optional Insecure Fallback (IP-only, not recommended) ─
# KEYCLOAK_HOSTNAME=
# KC_PROXY=none
# KC_HTTP_ENABLED=true
# KC_HOSTNAME_STRICT=false
# KC_HOSTNAME_STRICT_HTTPS=false
# KEYCLOAK_HOSTNAME_STRICT_BACKCHANNEL=false
# KEYCLOAK_PORT_EXPOSE=8080:8080
# OIDC_PUBLIC_ISSUER_URL=http://YOUR_SERVER_IP:8080/realms/iqb
# OIDC_REDIRECT_URI=http://YOUR_SERVER_IP/auth/callback
# CORS_ORIGIN=http://YOUR_SERVER_IP

# ── Database ──────────────────────────────────────────────
POSTGRES_DB=content_pool
POSTGRES_USER=content_pool
POSTGRES_PASSWORD=change-me-to-a-secure-password

# ── JWT ──────────────────────────────────────────────────
JWT_SECRET=change-me-to-a-random-string-at-least-32-chars
JWT_EXPIRATION=24h

# ── CORS ────────────────────────────────────────────────
CORS_ORIGIN=https://deine-domain.de

# ── Keycloak / OIDC ─────────────────────────────────────
# Keycloak runs as a Docker container in both dev and production.

# For IP-only deployments (no domain, no HTTPS):
# OIDC_ISSUER_URL=http://keycloak:8080/realms/iqb
# OIDC_PUBLIC_ISSUER_URL=http://YOUR_SERVER_IP:8080/realms/iqb
# OIDC_REDIRECT_URI=http://YOUR_SERVER_IP/auth/callback
# KEYCLOAK_COMMAND=["start-dev", "--import-realm"]
# KC_HTTP_ENABLED=true
# KC_HOSTNAME_STRICT_HTTPS=false

# For domain deployments with HTTPS:
OIDC_ISSUER_URL=http://keycloak:8080/realms/iqb
OIDC_PUBLIC_ISSUER_URL=http://localhost:8080/realms/iqb
OIDC_REDIRECT_URI=http://localhost:4200/auth/callback
OIDC_CLIENT_ID=contentpool
OIDC_SCOPE=openid profile email

# Keycloak Admin (required for production)
KEYCLOAK_ADMIN_USER=admin
KEYCLOAK_ADMIN_PASSWORD=change-me-to-a-secure-password

# Keycloak hostname settings (for domain deployments)
# KEYCLOAK_HOSTNAME=auth.yourdomain.com
# KEYCLOAK_HOSTNAME_STRICT=true
# KEYCLOAK_HOSTNAME_STRICT_BACKCHANNEL=false
# KC_HOSTNAME_STRICT_HTTPS=true
# KC_PROXY=edge
# KEYCLOAK_COMMAND=["start", "--optimized", "--import-realm"]

# ── Application Version (for server deployment with pre-built images) ──
# Set to a specific version like v0.1.0, or use 'latest' for testing
IMAGE_VERSION=latest

# ── Database ──────────────────────────────────────────────
POSTGRES_DB=content_pool
POSTGRES_USER=content_pool
POSTGRES_PASSWORD=change-me-to-a-secure-password

# ── JWT ──────────────────────────────────────────────────
JWT_SECRET=change-me-to-a-random-string-at-least-32-chars
JWT_EXPIRATION=24h

# ── CORS ────────────────────────────────────────────────
CORS_ORIGIN=https://deine-domain.de

# ── Keycloak / OIDC ─────────────────────────────────────
# Keycloak uses a separate PostgreSQL database for production.
# Choose ONE of the following deployment modes:

# ════════════════════════════════════════════════════════
# MODE 1: IP-ONLY DEPLOYMENT (HTTP - Less Secure)
# Use this when you only have a server IP address, no domain.
# ⚠️  WARNING: Tokens are transmitted unencrypted - security risk on public networks!
# ════════════════════════════════════════════════════════
# KEYCLOAK_HOSTNAME=                    # Leave empty for IP mode
# KEYCLOAK_COMMAND=["start-dev", "--import-realm"]
# KC_HTTP_ENABLED=true
# KC_HOSTNAME_STRICT_HTTPS=false
# KC_PROXY=none
# KEYCLOAK_PORT_EXPOSE=8080:8080        # Bind to all interfaces (or YOUR_IP:8080:8080)
# OIDC_ISSUER_URL=http://keycloak:8080/realms/iqb
# OIDC_PUBLIC_ISSUER_URL=http://YOUR_SERVER_IP:8080/realms/iqb
# OIDC_REDIRECT_URI=http://YOUR_SERVER_IP/auth/callback
# CORS_ORIGIN=http://YOUR_SERVER_IP

# ════════════════════════════════════════════════════════
# MODE 2: DOMAIN DEPLOYMENT (HTTPS - Recommended)
# Use this when you have a domain name with SSL certificates.
# ════════════════════════════════════════════════════════
KEYCLOAK_HOSTNAME=auth.yourdomain.com
KEYCLOAK_COMMAND=["start", "--optimized", "--import-realm"]
KC_HTTP_ENABLED=false
KC_HOSTNAME_STRICT_HTTPS=true
KC_PROXY=edge
KEYCLOAK_PORT_EXPOSE=127.0.0.1:8080:8080  # Local only - accessed via nginx proxy
OIDC_ISSUER_URL=http://keycloak:8080/realms/iqb
OIDC_PUBLIC_ISSUER_URL=https://auth.yourdomain.com/realms/iqb
OIDC_REDIRECT_URI=https://yourdomain.com/auth/callback
CORS_ORIGIN=https://yourdomain.com

# ════════════════════════════════════════════════════════
# Keycloak Database (PostgreSQL) - Required for both modes
# ════════════════════════════════════════════════════════
KEYCLOAK_DB_NAME=keycloak
KEYCLOAK_DB_USER=keycloak
KEYCLOAK_DB_PASSWORD=change-me-to-a-secure-password-for-keycloak-db

# ════════════════════════════════════════════════════════
# Keycloak Admin - CHANGE THESE DEFAULTS IN PRODUCTION
# ════════════════════════════════════════════════════════
KEYCLOAK_ADMIN_USER=admin
KEYCLOAK_ADMIN_PASSWORD=change-me-to-a-very-secure-password-min-12-chars

# OIDC Client Settings
OIDC_CLIENT_ID=contentpool
OIDC_SCOPE=openid profile email

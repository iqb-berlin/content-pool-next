# Backend
PORT=3000
NODE_ENV=development

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=contentpool
DB_PASSWORD=contentpool_dev
DB_DATABASE=contentpool

# JWT
JWT_SECRET=dev-secret-change-in-production
JWT_EXPIRATION=24h

# File Storage
FILE_STORAGE_PATH=./uploads

# App Defaults
DEFAULT_LANGUAGE=de

# OIDC / Keycloak Configuration
# Internal URL for backend API communication (Docker hostname or localhost)
OIDC_ISSUER_URL=http://localhost:8080/realms/iqb
# Public URL for frontend browser redirects (IP or domain accessible from browser)
OIDC_PUBLIC_ISSUER_URL=http://localhost:8080/realms/iqb
OIDC_CLIENT_ID=contentpool
OIDC_REDIRECT_URI=http://localhost:4200/auth/callback
OIDC_SCOPE=openid profile email
